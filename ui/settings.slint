import { LineEdit } from "std-widgets.slint";

component SectionButton inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked();
    height: 42px;
    border-radius: 8px;
    background: active ? #31434c : transparent;
    TouchArea { clicked => { root.clicked(); } }
    Text {
        text: root.label;
        color: root.active ? #f6fbff : #c3cbd4;
        font-size: 15px;
        font-weight: root.active ? 700 : 500;
        vertical-alignment: center;
        x: 18px;
        y: 0;
        height: parent.height;
    }
}

component ActionButton inherits Rectangle {
    in property <string> label;
    in property <bool> enabled: true;
    callback clicked();
    height: 38px;
    border-radius: 7px;
    background: enabled ? #1f7a68 : #d6dde3;
    TouchArea { enabled: root.enabled; clicked => { root.clicked(); } }
    Text {
        text: root.label;
        color: root.enabled ? #ffffff : #7b8792;
        font-size: 14px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
}

component QuietButton inherits Rectangle {
    in property <string> label;
    callback clicked();
    height: 38px;
    border-radius: 7px;
    background: #eef3f6;
    border-width: 1px;
    border-color: #dce5eb;
    TouchArea { clicked => { root.clicked(); } }
    Text {
        text: root.label;
        color: #26313b;
        font-size: 14px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
}

component ToggleRow inherits Rectangle {
    in property <string> label;
    in-out property <bool> checked;
    height: 34px;
    background: transparent;
    TouchArea { clicked => { root.checked = !root.checked; } }
    Rectangle {
        x: 0;
        y: 4px;
        width: 48px;
        height: 26px;
        border-radius: 13px;
        background: root.checked ? #35c7a8 : #d7e0e6;
        Rectangle {
            x: root.checked ? 24px : 4px;
            y: 4px;
            width: 18px;
            height: 18px;
            border-radius: 9px;
            background: white;
        }
    }
    Text {
        x: 62px;
        y: 0;
        height: parent.height;
        text: root.label;
        color: #26313b;
        font-size: 15px;
        vertical-alignment: center;
    }
}

component ValuePill inherits Rectangle {
    in property <string> value;
    height: 36px;
    border-radius: 8px;
    background: #f4f7f9;
    border-width: 1px;
    border-color: #dce5eb;
    Text {
        x: 14px;
        y: 0;
        width: parent.width - 28px;
        height: parent.height;
        text: root.value;
        color: #26313b;
        font-size: 14px;
        vertical-alignment: center;
    }
}

component Card inherits Rectangle {
    border-radius: 10px;
    background: #ffffff;
    border-width: 1px;
    border-color: #edf1f5;
}

component MeterBar inherits Rectangle {
    in property <float> level;
    height: 10px;
    border-radius: 5px;
    background: #e8eef2;
    Rectangle {
        width: parent.width * root.level;
        height: parent.height;
        border-radius: parent.border-radius;
        background: #35c7a8;
    }
}

export component SettingsWindow inherits Window {
    title: "Uvox Settings";
    preferred-width: 1040px;
    preferred-height: 720px;
    min-width: 980px;
    min-height: 660px;
    background: #f5f7fa;
    default-font-family: "Segoe UI";

    in-out property <int> section-index: 0;
    in-out property <string> status-title: "Ready";
    in-out property <string> status-detail: "Hold the configured hotkey to record. Release the final key to transcribe and type.";
    in-out property <string> microphone: "Default microphone";
    in-out property <float> input-level: 0.0;
    in-out property <string> active-model: "tdt_ctc-110m-f16.gguf";
    in-out property <[string]> model-labels;
    in-out property <[string]> model-files;
    in-out property <int> selected-model-index: 0;
    in-out property <string> selected-model-label: "tdt_ctc-110m | f16 | 268 MB | recommended";
    in-out property <int> typing-chunk: 3;
    in-out property <int> typing-interval-ms: 20;
    in-out property <int> idle-timeout-secs: 180;
    in-out property <bool> start-with-windows: false;
    in-out property <bool> hotkey-enabled: true;
    in-out property <string> record-hotkey: "CapsLock+S";
    in-out property <string> log-level: "Minimal";
    in-out property <string> test-transcript: "";
    in-out property <string> progress-text: "";
    in-out property <bool> busy: false;

    in-out property <[string]> microphone-labels;
    in-out property <int> selected-microphone-index: 0;
    in-out property <bool> capslock-always-off: false;
    in-out property <bool> selected-model-downloaded: false;
    in-out property <string> parakeet-runtime-dir;
    in-out property <string> parakeet-model-path;
    in-out property <bool> recording-test: false;
    in-out property <bool> recording-hotkey: false;

    callback save-requested();
    callback reset-requested();
    callback record-test-requested();
    callback stop-test-requested();
    callback model-test-requested();
    callback download-requested(int);
    callback open-log-requested();
    callback record-hotkey-requested();
    callback clear-hotkey-requested();
    callback reset-hotkey-requested();
    callback model-delta(int);
    callback microphone-delta(int);
    callback typing-chunk-delta(int);
    callback typing-interval-delta(int);
    callback idle-timeout-delta(int);
    callback log-level-delta(int);

    Rectangle {
        x: 0;
        y: 0;
        width: 240px;
        height: parent.height;
        background: #181d23;
    }

    Text {
        text: "Uvox";
        x: 34px;
        y: 32px;
        color: #f7fbff;
        font-size: 28px;
        font-weight: 800;
    }

    VerticalLayout {
        x: 24px;
        y: 108px;
        width: 192px;
        spacing: 8px;
        SectionButton { label: "General"; active: root.section-index == 0; clicked => { root.section-index = 0; } }
        SectionButton { label: "Audio"; active: root.section-index == 1; clicked => { root.section-index = 1; } }
        SectionButton { label: "Model"; active: root.section-index == 2; clicked => { root.section-index = 2; } }
        SectionButton { label: "Typing"; active: root.section-index == 3; clicked => { root.section-index = 3; } }
        SectionButton { label: "Logging"; active: root.section-index == 4; clicked => { root.section-index = 4; } }
        SectionButton { label: "Advanced"; active: root.section-index == 5; clicked => { root.section-index = 5; } }
    }

    VerticalLayout {
        x: 278px;
        y: 28px;
        width: parent.width - 316px;
        height: parent.height - 56px;
        spacing: 16px;

        Card {
            height: 92px;
            Text { text: root.status-title; x: 24px; y: 20px; color: #1e252c; font-size: 24px; font-weight: 800; }
            Text { text: root.status-detail; x: 24px; y: 54px; color: #596674; font-size: 15px; }
            Text { text: root.progress-text; x: parent.width - 330px; y: 36px; width: 300px; color: #2b9c84; horizontal-alignment: right; font-size: 14px; }
        }

        Rectangle {
            height: 512px;

            Card {
                visible: root.section-index == 0;
                width: parent.width;
                height: parent.height;
                Text { text: "General"; x: 24px; y: 22px; color: #1e252c; font-size: 24px; font-weight: 800; }
                Text { text: "Hotkey"; x: 24px; y: 82px; color: #596674; font-size: 15px; }
                ToggleRow { x: 180px; y: 74px; width: 420px; label: "Enable dictation hotkey"; checked <=> root.hotkey-enabled; }
                Text { text: "Current hotkey"; x: 24px; y: 132px; color: #596674; font-size: 15px; }
                ValuePill { x: 180px; y: 124px; width: 210px; value: root.record-hotkey; }
                QuietButton { x: 404px; y: 124px; width: 126px; label: root.recording-hotkey ? "Cancel" : "Record Hotkey"; clicked => { root.record-hotkey-requested(); } }
                QuietButton { x: 544px; y: 124px; width: 72px; label: "Clear"; clicked => { root.clear-hotkey-requested(); } }
                QuietButton { x: 630px; y: 124px; width: 118px; label: "Reset Default"; clicked => { root.reset-hotkey-requested(); } }
                Text { text: "Startup"; x: 24px; y: 194px; color: #596674; font-size: 15px; }
                ToggleRow { x: 180px; y: 186px; width: 420px; label: "Start Uvox with Windows"; checked <=> root.start-with-windows; }
                Text { text: "Caps Lock State"; x: 24px; y: 244px; color: #596674; font-size: 15px; }
                ToggleRow { x: 180px; y: 236px; width: 420px; label: "Always force CapsLock off"; checked <=> root.capslock-always-off; }
                Text { text: "Status"; x: 24px; y: 302px; color: #596674; font-size: 15px; }
                Text { text: "Tray utility running locally. Some reserved Windows shortcuts cannot be intercepted."; x: 180px; y: 302px; width: 560px; color: #1e252c; font-size: 15px; wrap: word-wrap; }
            }

            Card {
                visible: root.section-index == 1;
                width: parent.width;
                height: parent.height;
                Text { text: "Audio"; x: 24px; y: 22px; color: #1e252c; font-size: 24px; font-weight: 800; }
                Text { text: "Microphone"; x: 24px; y: 86px; color: #596674; font-size: 15px; }
                QuietButton { x: 180px; y: 78px; width: 42px; label: "<"; clicked => { root.microphone-delta(-1); } }
                ValuePill { x: 232px; y: 78px; width: 308px; value: root.microphone; }
                QuietButton { x: 550px; y: 78px; width: 42px; label: ">"; clicked => { root.microphone-delta(1); } }
                Text { text: "Input level"; x: 24px; y: 150px; color: #596674; font-size: 15px; }
                MeterBar { x: 180px; y: 154px; width: 360px; level: root.input-level; }
                if !root.recording-test : ActionButton { x: 604px; y: 76px; width: 110px; label: "Record"; enabled: !root.busy; clicked => { root.record-test-requested(); } }
                if root.recording-test : ActionButton { x: 604px; y: 76px; width: 110px; label: "Stop"; clicked => { root.stop-test-requested(); } }
                Text { text: "Transcript"; x: 24px; y: 214px; color: #596674; font-size: 15px; }
                Rectangle { x: 180px; y: 210px; width: 540px; height: 170px; border-radius: 8px; background: #f4f7f9; border-width: 1px; border-color: #dce5eb; }
                Text { x: 196px; y: 226px; width: 508px; height: 130px; text: root.test-transcript; color: #26313b; font-size: 14px; wrap: word-wrap; }
            }

            Card {
                visible: root.section-index == 2;
                width: parent.width;
                height: parent.height;
                Text { text: "Model"; x: 24px; y: 22px; color: #1e252c; font-size: 24px; font-weight: 800; }
                Text { text: "Active model"; x: 24px; y: 86px; color: #596674; font-size: 15px; }
                Text { text: root.active-model; x: 180px; y: 86px; width: 520px; color: #1e252c; font-size: 15px; }
                Text { text: "Approved model"; x: 24px; y: 142px; color: #596674; font-size: 15px; }
                QuietButton { x: 180px; y: 134px; width: 42px; label: "<"; clicked => { root.model-delta(-1); } }
                ValuePill { x: 232px; y: 134px; width: 366px; value: root.selected-model-label; }
                QuietButton { x: 608px; y: 134px; width: 42px; label: ">"; clicked => { root.model-delta(1); } }
                ActionButton { x: 594px; y: 188px; width: 120px; label: root.selected-model-downloaded ? "Select Model" : "Download"; enabled: !root.busy; clicked => { root.download-requested(root.selected-model-index); } }
                QuietButton { x: 594px; y: 82px; width: 120px; label: "Test Model"; clicked => { root.model-test-requested(); } }
                Text { text: "F16 models are recommended. Quantized models use less disk/VRAM but may reduce quality."; x: 180px; y: 250px; width: 520px; color: #596674; font-size: 14px; wrap: word-wrap; }
            }

            Card {
                visible: root.section-index == 3;
                width: parent.width;
                height: parent.height;
                Text { text: "Typing"; x: 24px; y: 22px; color: #1e252c; font-size: 24px; font-weight: 800; }
                Text { text: "Chunk size"; x: 24px; y: 88px; color: #596674; font-size: 15px; }
                QuietButton { x: 180px; y: 80px; width: 38px; label: "-"; clicked => { root.typing-chunk-delta(-1); } }
                ValuePill { x: 228px; y: 80px; width: 90px; value: root.typing-chunk; }
                QuietButton { x: 328px; y: 80px; width: 38px; label: "+"; clicked => { root.typing-chunk-delta(1); } }
                Text { text: "Typing interval"; x: 24px; y: 148px; color: #596674; font-size: 15px; }
                MeterBar { x: 180px; y: 154px; width: 300px; level: root.typing-interval-ms / 200; }
                Text { text: root.typing-interval-ms + " ms"; x: 500px; y: 148px; color: #1e252c; font-size: 15px; }
                QuietButton { x: 570px; y: 140px; width: 38px; label: "-"; clicked => { root.typing-interval-delta(-5); } }
                QuietButton { x: 618px; y: 140px; width: 38px; label: "+"; clicked => { root.typing-interval-delta(5); } }
                Text { text: "Model unload"; x: 24px; y: 208px; color: #596674; font-size: 15px; }
                LineEdit { x: 180px; y: 200px; width: 140px; height: 36px; text: root.idle-timeout-secs; input-type: number; edited(t) => { root.idle-timeout-secs = t.to-float(); } }
                Text { text: "seconds"; x: 332px; y: 208px; color: #596674; font-size: 15px; }
            }

            Card {
                visible: root.section-index == 4;
                width: parent.width;
                height: parent.height;
                Text { text: "Logging"; x: 24px; y: 22px; color: #1e252c; font-size: 24px; font-weight: 800; }
                Text { text: "Level"; x: 24px; y: 86px; color: #596674; font-size: 15px; }
                QuietButton { x: 180px; y: 78px; width: 38px; label: "<"; clicked => { root.log-level-delta(-1); } }
                ValuePill { x: 228px; y: 78px; width: 172px; value: root.log-level; }
                QuietButton { x: 410px; y: 78px; width: 38px; label: ">"; clicked => { root.log-level-delta(1); } }
                QuietButton { x: 480px; y: 78px; width: 160px; label: "Open Latest Log"; clicked => { root.open-log-requested(); } }
                Text { text: "Each launch replaces latest.log. Extreme logging can grow quickly during hotkey/audio debugging."; x: 180px; y: 140px; width: 500px; color: #596674; font-size: 14px; wrap: word-wrap; }
            }

            Card {
                visible: root.section-index == 5;
                width: parent.width;
                height: parent.height;
                Text { text: "Advanced"; x: 24px; y: 22px; color: #1e252c; font-size: 24px; font-weight: 800; }
                Text { text: "Runtime Directory"; x: 24px; y: 86px; color: #596674; font-size: 15px; }
                LineEdit { x: 180px; y: 78px; width: 500px; height: 36px; text: root.parakeet-runtime-dir; edited(t) => { root.parakeet-runtime-dir = t; } }
                Text { text: "Model Path"; x: 24px; y: 146px; color: #596674; font-size: 15px; }
                LineEdit { x: 180px; y: 138px; width: 500px; height: 36px; text: root.parakeet-model-path; edited(t) => { root.parakeet-model-path = t; } }
            }
        }

        HorizontalLayout {
            alignment: end;
            height: 44px;
            spacing: 12px;
            QuietButton { width: 110px; label: "Reset"; clicked => { root.reset-requested(); } }
            ActionButton { width: 110px; label: "Save"; clicked => { root.save-requested(); } }
        }
    }
}

export component RecordingOverlay inherits Window {
    preferred-width: 320px;
    preferred-height: 92px;
    background: transparent;
    no-frame: true;
    always-on-top: true;
    default-font-family: "Segoe UI";

    in-out property <float> level: 0.25;

    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        border-radius: 24px;
        background: #10161bdd;
    }
    for bar[index] in 16 : Rectangle {
        width: 10px;
        height: 18px + root.level * (28px + Math.mod(index, 6) * 6px);
        x: 39px + index * 15px;
        y: (parent.height - self.height) / 2;
        border-radius: 5px;
        background: #45dcc0;
    }
}
